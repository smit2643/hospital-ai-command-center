DEBUG=True
SECRET_KEY=change-me
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
SITE_BASE_URL=http://localhost:8000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hospital_ai
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Hospital AI <no-reply@hospital-ai.local>
MEDIA_ROOT=media
MEDIA_URL=/media/
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_TASK_ALWAYS_EAGER=False
SIGN_LINK_TTL_HOURS=48
SIGNATURE_EMAIL_DELIVERY=sync
OCR_PROVIDER=tesseract
SUMMARY_LLM_PROVIDER=rule_based
# Optional Gemini provider:
# OCR_PROVIDER=gemini
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-1.5-flash
# SUMMARY_LLM_PROVIDER=gemini
# SUMMARY_GEMINI_MODEL=gemini-2.0-flash-lite
